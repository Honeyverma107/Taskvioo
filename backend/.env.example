# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/taskvio?schema=public"

# Secret for JWT signing (use a long random string in production)
JWT_SECRET="change-me-to-a-long-random-string"

# Server port (optional, default 5000)
PORT=5000

# Frontend URL for CORS (required in production)
CLIENT_URL="http://localhost:5173"
